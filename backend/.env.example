APP_ENVIRONMENT=local
APP_DEBUG=false
APP_LOG_LEVEL=INFO
APP_LOG_FORMAT=console
APP_DOCS_ENABLED=true
APP_CORS_ORIGINS=["http://localhost:5173"]
APP_TRUSTED_HOSTS=["localhost","127.0.0.1"]
APP_OTEL_ENABLED=false
APP_OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317
APP_OTEL_SERVICE_NAME=fleet-dispatch-backend

# Khong dung prefix APP_ - cung ten voi ml/.env.example de dung chung 1
# K8s Secret cho ca pipeline data (ml/) lan backend. Thieu bien nay ->
# /api/v1/routes/estimate tu dong fallback Haversine, khong loi.
GOOGLE_ROUTES_API_KEY=
# Thieu bien nay -> /api/v1/geocoding/lookup tra ve 503, khong co fallback
# hop ly cho geocoding (xem ml/geocoding_client.py).
GOOGLE_GEOCODING_API_KEY=
